@{
    ViewData["Title"] = "Bedankt";
}

<h1>Bedankt!</h1>

<p>Bedankt, @TempData["ThanksName"]. We nemen contact op via @TempData["ThanksEmail"].</p>
<p>Je bericht:</p>
<div class="message-preview">@Html.Raw(TempData["ThanksMessage"])</div>

<a href="/contact" role="button">Terug naar formulier</a>